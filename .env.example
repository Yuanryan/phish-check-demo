# Leave blank to run zero-setup in MOCK mode (deterministic, no API call).
# Provider is auto-detected from the key prefix:
#   sk-ant-...        -> Claude (Anthropic)
#   sk-... / sk-proj-... -> GPT (OpenAI)
LLM_API_KEY=

# Optional model override.
#   Anthropic default: claude-opus-4-8
#   OpenAI default:    gpt-4o-mini
LLM_MODEL=
