# =============================================================================
# PhishCheck LLM configuration
# Copy this file to `.env` and fill in your API keys:
#   cp .env.example .env
# =============================================================================

# --- Primary: Google Gemini (recommended) ------------------------------------
# Get a free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Default model: gemini-2.5-flash (fast, good free-tier quota)
GEMINI_MODEL=gemini-2.5-flash

# --- Fallback: Groq (used when Gemini fails, e.g. daily quota exhausted) ---
# Get a free key: https://console.groq.com/keys
GROQ_API_KEY=

# Comma-separated list, tried in order (best reasoning first).
# Recommended free-tier models (June 2026):
#   llama-3.3-70b-versatile  — strongest general reasoning
#   openai/gpt-oss-120b      — newer OSS model, high quality
#   llama-3.1-8b-instant     — fastest, good when larger models are rate-limited
GROQ_MODELS=llama-3.3-70b-versatile,openai/gpt-oss-120b,llama-3.1-8b-instant

# Optional: use a single Groq model instead of the list above
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Fallback chain ----------------------------------------------------------
# 1. Gemini (GEMINI_API_KEY) → structured JSON via response_json_schema
# 2. Groq   (GROQ_API_KEY)   → tries GROQ_MODELS in order
# 3. Mock   (no keys / all failed) → deterministic rule-based verdict
